#!/usr/bin/env bash
# DO NOT EDIT — this file is generated from cm.yaml and will be overwritten.
# To make changes, edit cm.yaml and run: cm update
# Generated by container-magic: https://github.com/markhedleyjones/container-magic

set -euo pipefail

# Configuration
IMAGE_NAME="{{ project_name }}"
WORKSPACE_NAME="{{ workspace_name }}"
USER_NAME="{{ production_user_name }}"
USER_UID="{{ production_user_uid }}"
USER_GID="{{ production_user_gid }}"
WORKDIR="{{ production_user_home }}"
TARGET="{{ default_target }}"
TAG="latest"

# Detect runtime backend
{%- if backend == "auto" %}
if command -v podman >/dev/null 2>&1; then
	RUNTIME="podman"
elif command -v docker >/dev/null 2>&1; then
	RUNTIME="docker"
else
	echo "Error: Neither podman nor docker found in PATH" >&2
	exit 1
fi
{%- else %}
RUNTIME="{{ backend }}"
{%- endif %}

# Parse arguments
while [[ $# -gt 0 ]]; do
	case "$1" in
	--uid)
		USER_UID="$2"
		shift 2
		;;
	--gid)
		USER_GID="$2"
		shift 2
		;;
	--tag)
		TAG="$2"
		shift 2
		;;
	--help | -h)
		echo "Usage: $0 [options]"
		echo ""
		echo "Build a Docker image for the {{ default_target }} target stage."
		echo ""
		echo "Options:"
		echo "  --tag TAG     Override image tag (default: latest)"
		echo "  --uid UID     Override user UID (default: $USER_UID)"
		echo "  --gid GID     Override user GID (default: $USER_GID)"
		exit 0
		;;
	*)
		echo "Error: Unknown argument '$1'" >&2
		echo "Use '$0 --help' for more information" >&2
		exit 1
		;;
	esac
done

echo "Building image: ${IMAGE_NAME}:${TAG} (target: ${TARGET})"

${RUNTIME} build \
	--target "${TARGET}" \
	--build-arg USER_NAME="${USER_NAME}" \
	--build-arg USER_UID="${USER_UID}" \
	--build-arg USER_GID="${USER_GID}" \
	--build-arg WORKSPACE_NAME="${WORKSPACE_NAME}" \
	--tag "${IMAGE_NAME}:${TAG}" \
	.

echo "Image built successfully: ${IMAGE_NAME}:${TAG}"
echo "Workspace included in image at: ${WORKDIR}/${WORKSPACE_NAME}"
echo ""
echo "To run the image, use: ./run.sh [command]"
